# Local debug-only settings.
# Copy to .env.debug.local and set your own values.

# Show debug panel in app (enabled by default in unpackaged dev mode).
ALTERE_DEBUG_TOOLS=1

# Release channel label shown in debug snapshot.
ALTERE_RELEASE_CHANNEL=beta

# Optional alternate auth backend for local testing.
# ALTERE_AUTH_API_BASE=http://132.243.30.159:3000
# ALTERE_AUTH_API_FALLBACKS=http://83.147.241.28

# Optional URL for a dedicated debug Telegram bot.
# Example: https://t.me/your_debug_bot
ALTERE_DEBUG_BOT_URL=

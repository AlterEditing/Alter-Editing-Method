{
  "name": "Alter-Editing-Video-Patcher",
  "version": "1.2.2",
  "description": "Alter Editing video patcher ",
  "author": "Alter Editing",
  "license": "GPL-3.0-only",
  "private": true,
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "dev:debug": "set ALTERE_DEBUG_TOOLS=1&& electron .",
    "check": "node --check src/main/main.js && node --check src/main/services/elst-patcher.js && node --check src/main/services/ffmpeg.js && node --check src/main/services/settings-store.js && node --check src/main/services/update-service.js && node --check src/main/services/video-service.js && node --check src/preload/preload.js && node --check src/renderer/app.js",
    "dist:win": "electron-builder --win nsis --publish never",
    "release:win": "electron-builder --win nsis --publish always",
    "release:win:draft": "electron-builder --win nsis --publish always --config.publish.releaseType=draft",
    "release:win:draft:stable": "electron-builder --win nsis --publish always --config.publish.releaseType=draft",
    "release:win:draft:beta": "electron-builder --win nsis --publish always --config.publish.releaseType=prerelease",
    "release:win:draft:alpha": "electron-builder --win nsis --publish always --config.publish.releaseType=prerelease",
    "version:alpha": "npm version prerelease --preid alpha --no-git-tag-version",
    "version:beta": "npm version prerelease --preid beta --no-git-tag-version"
  },
  "dependencies": {
    "electron-updater": "^6.6.2"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3",
    "electron": "^41.3.0"
  }
}
